# Optional — all auto-generated on first boot if not set

# Database (default: SQLite at /data/db.sqlite)
# Set to a PostgreSQL URL to use Postgres instead:
# DATABASE_URL=postgresql://user:password@host:5432/registry_admin

# Feature flags (both enabled by default — set to 'false' to disable)
ENABLE_DOCKER=true
ENABLE_MAVEN=true

# Public-facing URL — used for Docker auth realm, Maven snippets, and login cookies
# Use https:// when served over TLS; http:// for plain HTTP (required for session cookies)
PUBLIC_URL=http://localhost:3000

# Override session cookie Secure flag (default: true when PUBLIC_URL is https://, false for http://)
# COOKIE_SECURE=false

# Admin credentials (auto-generated password printed to logs on first boot)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Set ADMIN_PASSWORD and ADMIN_RESET_PASSWORD=true once to reset an existing admin password
# ADMIN_RESET_PASSWORD=true

# Secrets (auto-generated if not set — set manually to persist across recreates)
TOKEN_SECRET=
WEBHOOK_SECRET=
REGISTRY_SECRET=

# Trivy (binary + vuln/Java DBs) are downloaded to /data/trivy on first container start
# TRIVY_VERSION=0.71.0
# TRIVY_ROOT=/data/trivy
# TRIVY_CACHE_DIR=/data/trivy/cache
# TRIVY_MODULE_DIR=/data/trivy/modules
# TRIVY_DB_REPOSITORY=public.ecr.aws/aquasecurity/trivy-db:2,ghcr.io/aquasecurity/trivy-db:2
# TRIVY_JAVA_DB_REPOSITORY=public.ecr.aws/aquasecurity/trivy-java-db:1,ghcr.io/aquasecurity/trivy-java-db:1
# TRIVY_SKIP_DB_UPDATE=true
# Set TRIVY_SKIP_DB_UPDATE=false to refresh DBs from the network on each scan
# Scheduled update (cron): DBs daily at 03:15; binary when TRIVY_VERSION changes
# TRIVY_UPDATE_CRON=15 3 * * *
# TRIVY_UPDATE_CRON=off
# TRIVY_UPDATE_BINARY=true
